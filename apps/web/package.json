    "@cloudflare/vite-plugin": "1.6.0",
    "@cloudflare/workers-types": "^4.20260621.1",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vite": "^6.4.3",
    "wrangler": "4.20.0"
